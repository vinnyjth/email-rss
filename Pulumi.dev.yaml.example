config:
  aws:region: us-east-1
  # Apex domain you control; inbound mail uses <inboxSubdomain>.<domain>.
  email-rss:domain: example.com
  email-rss:inboxSubdomain: inbox
  # Amazon Polly voice + engine. Engine: neural | standard | generative.
  email-rss:ttsVoice: Matthew
  email-rss:ttsEngine: neural
  # Optional: if your DNS is in Route53, set the zone id to auto-create records.
  # email-rss:route53ZoneId: Z0123456789ABCDEFGHIJ
  # Optional custom hostname (ACM cert must be in us-east-1):
  # email-rss:appHost: app.example.com
  # email-rss:acmCertArn: arn:aws:acm:us-east-1:123456789012:certificate/...
  # Optional: pin a local AWS profile for this stack:
  # aws:profile: your-profile
